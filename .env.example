PORT=8081
ENV=development

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=ticdesk
DB_PASSWORD=ticdesk_secret
DB_NAME=ticdesk
DB_SSLMODE=disable

# Session Secret (Min 32 bytes)
SESSION_SECRET=super-secret-key-change-in-production-32bytes

# ticMail Built-in Notification Engine
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=notifications@ticdesk.com
